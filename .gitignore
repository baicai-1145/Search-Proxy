# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#.idea/

# search-proxy: runtime data
data/
*.db
*.db-shm
*.db-wal

# search-proxy: config with secrets
search-proxy.toml
.env
.env.*

# search-proxy: webui frontend build artifacts
webui/node_modules/
webui/dist/
